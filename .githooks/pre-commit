#!/bin/bash
# pre-commit hook: 当 skill 文件变更时自动运行一致性检查
# 激活方式: git config core.hooksPath .githooks
# 结果写入 .skill-check-report（gitignored），终端显示摘要

REPORT=".skill-check-report"

# 检测暂存区是否有 skill 相关文件变更
SKILL_FILES=$(git diff --cached --name-only -- \
    'scm-prd-workflow/SKILL.md' \
    'scm-prd-workflow/references/*.md' \
    'scm-prd-workflow/templates/*.md' \
    'scm-prd-workflow/scripts/*.py' \
    'scm-prd-workflow/scripts/*.mjs' \
    'scm-knowledge-curator/SKILL.md' \
    'scm-knowledge-curator/references/*.md' \
    'scm-knowledge-curator/templates/*.md' \
    'scm-knowledge-curator/scripts/*.py' \
)

if [ -z "$SKILL_FILES" ]; then
    exit 0  # 没有 skill 文件变更，跳过
fi

# 初始化 report
{
    echo "# Skill Check Report"
    echo "时间: $(date '+%Y-%m-%d %H:%M:%S')"
    echo "变更文件:"
    echo "$SKILL_FILES" | sed 's/^/  - /'
    echo ""
} > "$REPORT"

HAS_PROBLEM=0

# 运行 prd-workflow 自检（完整报告写入文件，摘要输出到终端）
if [ -f "scm-prd-workflow/scripts/check-skill-consistency.py" ]; then
    SHORT=$(python3 scm-prd-workflow/scripts/check-skill-consistency.py scm-prd-workflow --short 2>&1)
    FULL=$(python3 scm-prd-workflow/scripts/check-skill-consistency.py scm-prd-workflow 2>&1)

    echo "## Skill 一致性检查" >> "$REPORT"
    echo '```' >> "$REPORT"
    echo "$FULL" >> "$REPORT"
    echo '```' >> "$REPORT"
    echo "" >> "$REPORT"

    echo "  $SHORT"

    if echo "$SHORT" | grep -q "critical"; then
        HAS_PROBLEM=1
    fi
fi

# 运行测试（如果有脚本/测试文件变更）
TEST_FILES=$(git diff --cached --name-only -- 'tests/*.py' 'scm-*/scripts/*.py')
if [ -n "$TEST_FILES" ] && command -v python3 >/dev/null 2>&1; then
    if python3 -c "import pytest" 2>/dev/null; then
        PYTEST_FULL=$(python3 -m pytest tests/ -v --tb=short 2>&1)
        PYTEST_SHORT=$(echo "$PYTEST_FULL" | tail -1)

        echo "## 测试结果" >> "$REPORT"
        echo '```' >> "$REPORT"
        echo "$PYTEST_FULL" >> "$REPORT"
        echo '```' >> "$REPORT"

        echo "  $PYTEST_SHORT"

        if echo "$PYTEST_SHORT" | grep -q "failed"; then
            HAS_PROBLEM=1
        fi
    fi
fi

# 结论
if [ "$HAS_PROBLEM" -eq 1 ]; then
    echo "" >> "$REPORT"
    echo "## 结论: 提交被阻止" >> "$REPORT"
    echo ""
    echo "提交被阻止。完整报告: cat $REPORT"
    exit 1
else
    echo "" >> "$REPORT"
    echo "## 结论: 通过" >> "$REPORT"
fi
