#!/bin/bash
# pre-commit hook: 当 skill 文件变更时自动运行一致性检查
# 激活方式: git config core.hooksPath .githooks
# 结果写入 .skill-check-report（gitignored），终端显示摘要

REPORT=".skill-check-report"

# 检测暂存区是否有 skill 相关文件变更
SKILL_FILES=$(git diff --cached --name-only -- \
    'scm-prd-workflow/SKILL.md' \
    'scm-prd-workflow/references/*.md' \
    'scm-prd-workflow/templates/*.md' \
    'scm-prd-workflow/scripts/*.py' \
    'scm-prd-workflow/scripts/*.mjs' \
    'scm-knowledge-curator/SKILL.md' \
    'scm-knowledge-curator/references/*.md' \
    'scm-knowledge-curator/templates/*.md' \
    'scm-knowledge-curator/scripts/*.py' \
)

if [ -z "$SKILL_FILES" ]; then
    # 非 skill 文件提交：只跑发版检测（轻量，~0.5秒）
    if [ -f "scm-prd-workflow/scripts/check-skill-consistency.py" ]; then
        RELEASE_CHECK=$(python3 scm-prd-workflow/scripts/check-skill-consistency.py scm-prd-workflow --short 2>&1)
        if echo "$RELEASE_CHECK" | grep -q "建议发版"; then
            echo ""
            echo "  ━━━ 发版提醒 ━━━"
            echo "  $RELEASE_CHECK"
            echo "  ━━━━━━━━━━━━━━━━"
            # 关键级别阻断提交
            if echo "$RELEASE_CHECK" | grep -q "critical"; then
                echo ""
                echo "  发版已严重滞后，提交被阻止。请先发版或使用 git commit --no-verify 跳过。"
                exit 1
            fi
        fi
    fi
    exit 0
fi

# 初始化 report
{
    echo "# Skill Check Report"
    echo "时间: $(date '+%Y-%m-%d %H:%M:%S')"
    echo "变更文件:"
    echo "$SKILL_FILES" | sed 's/^/  - /'
    echo ""
} > "$REPORT"

HAS_PROBLEM=0

# 运行 prd-workflow 自检（完整报告写入文件，摘要输出到终端）
if [ -f "scm-prd-workflow/scripts/check-skill-consistency.py" ]; then
    SHORT=$(python3 scm-prd-workflow/scripts/check-skill-consistency.py scm-prd-workflow --short 2>&1)
    FULL=$(python3 scm-prd-workflow/scripts/check-skill-consistency.py scm-prd-workflow 2>&1)

    echo "## Skill 一致性检查" >> "$REPORT"
    echo '```' >> "$REPORT"
    echo "$FULL" >> "$REPORT"
    echo '```' >> "$REPORT"
    echo "" >> "$REPORT"

    echo "  $SHORT"

    if echo "$SHORT" | grep -q "critical"; then
        HAS_PROBLEM=1
    fi

    # 发版提醒（醒目展示）
    if echo "$SHORT" | grep -q "建议发版"; then
        echo ""
        echo "  ━━━ 发版提醒 ━━━"
        echo "  $(echo "$SHORT" | grep -o '自 v[^ ]* .*')"
        echo "  ━━━━━━━━━━━━━━━━"
    fi

    # 存量测试覆盖：从完整报告中提取测试覆盖警告
    COVERAGE_WARNINGS=$(echo "$FULL" | grep '测试覆盖' | head -5)
    if [ -n "$COVERAGE_WARNINGS" ]; then
        echo "  测试覆盖提醒:"
        echo "$COVERAGE_WARNINGS" | while read -r line; do echo "    $line"; done
    fi
fi

# 测试新鲜度检查：脚本改了但对应测试没改 → 提醒
CHANGED_SCRIPTS=$(git diff --cached --name-only -- 'scm-*/scripts/*.py')
if [ -n "$CHANGED_SCRIPTS" ]; then
    while IFS= read -r script; do
        [ -z "$script" ] && continue
        module=$(basename "$script" .py | tr '-' '_')
        { [ "$module" = "__init__" ] || [ "$module" = "check_skill_consistency" ]; } && continue
        # 检查对应测试是否也在本次变更中
        if ! git diff --cached --name-only -- "tests/test_${module}*.py" | grep -q .; then
            # 测试文件存在但未修改 → 提醒（不阻止）
            if ls tests/test_${module}*.py >/dev/null 2>&1; then
                echo "  提醒: $script 已修改但 tests/test_${module}.py 未更新 — 确认测试仍然有效"
            fi
        fi
    done <<< "$CHANGED_SCRIPTS"
fi

# 运行测试（如果有脚本/测试文件变更）
TEST_FILES=$(git diff --cached --name-only -- 'tests/*.py' 'scm-*/scripts/*.py')
if [ -n "$TEST_FILES" ] && command -v python3 >/dev/null 2>&1; then
    if python3 -c "import pytest" 2>/dev/null; then
        PYTEST_FULL=$(python3 -m pytest tests/ -v --tb=short 2>&1)
        PYTEST_SHORT=$(echo "$PYTEST_FULL" | tail -1)

        echo "## 测试结果" >> "$REPORT"
        echo '```' >> "$REPORT"
        echo "$PYTEST_FULL" >> "$REPORT"
        echo '```' >> "$REPORT"

        echo "  $PYTEST_SHORT"

        if echo "$PYTEST_SHORT" | grep -q "failed"; then
            HAS_PROBLEM=1
        fi
    fi
fi

# 新增脚本必须有测试（硬性阻止）
NEW_SCRIPTS=$(git diff --cached --name-only --diff-filter=A -- 'scm-*/scripts/*.py')
if [ -n "$NEW_SCRIPTS" ]; then
    echo "" >> "$REPORT"
    echo "## 新增文件检查" >> "$REPORT"
    while IFS= read -r script; do
        [ -z "$script" ] && continue
        module=$(basename "$script" .py | tr '-' '_')
        # 排除 __init__.py 和 check-skill-consistency 自身
        if [ "$module" = "__init__" ] || [ "$module" = "check_skill_consistency" ]; then
            continue
        fi
        # 检查暂存区或已有文件中是否有对应测试
        has_test=0
        git diff --cached --name-only | grep -q "test_${module}" && has_test=1
        ls tests/test_${module}*.py >/dev/null 2>&1 && has_test=1
        if [ "$has_test" -eq 0 ]; then
            echo "  - 阻止: $script 无对应测试 tests/test_${module}.py" >> "$REPORT"
            echo "  阻止: 新增脚本 $script 无对应测试 tests/test_${module}.py"
            HAS_PROBLEM=1
        fi
    done <<< "$NEW_SCRIPTS"
fi

# 新增文档提醒（非阻止，仅提示）
NEW_DOCS=$(git diff --cached --name-only --diff-filter=A -- \
    'scm-*/references/*.md' 'scm-*/templates/*.md')
if [ -n "$NEW_DOCS" ]; then
    while IFS= read -r f; do
        [ -z "$f" ] && continue
        case "$f" in
            */references/*.md)
                echo "  新增 reference: $f → 检查 SKILL.md 加载表"
                echo "  - $f → 检查加载表" >> "$REPORT"
                ;;
            */templates/*.md)
                echo "  新增 template: $f → 检查占位符"
                echo "  - $f → 检查占位符" >> "$REPORT"
                ;;
        esac
    done <<< "$NEW_DOCS"
fi

# 结论
if [ "$HAS_PROBLEM" -eq 1 ]; then
    echo "" >> "$REPORT"
    echo "## 结论: 提交被阻止" >> "$REPORT"
    echo ""
    echo "提交被阻止。完整报告: cat $REPORT"
    exit 1
else
    echo "" >> "$REPORT"
    echo "## 结论: 通过" >> "$REPORT"
fi
