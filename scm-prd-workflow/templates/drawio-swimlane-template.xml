<?xml version="1.0" encoding="UTF-8"?>
<!--
  draw.io 泳道图参考模板（横向排列泳道）

  布局说明:
  - 泳道横向排列：每条泳道是一个竖直的列，从左到右排列
  - 流程从上往下：节点在泳道列内纵向排列
  - 跨泳道连线：边在不同列之间横向连接

  结构说明:
  - mxCell id="0": 固定的根层
  - mxCell id="1": 默认绘图层
  - Title (id="10"): 图表标题，文本元素
  - Lane (id="11/12/13"): 泳道列，swimlane 容器，横向排列
    - 每条泳道有独立的边框，形成自然的列分隔
    - startSize=30: 泳道标题栏高度（列顶部显示标题）
    - horizontal=1: 标题在顶部水平显示
  - Node (id="20-25"): 节点，坐标相对于所属泳道列
  - Edge (id="30-35"): 连线，parent="1"（顶层），支持跨泳道

  SCM 色板:
    OMS蓝: fill=#dae8fc stroke=#6c8ebf
    WMS绿: fill=#d5e8d4 stroke=#82b366
    TMS橙: fill=#ffe6cc stroke=#d6b656
    BMS紫: fill=#e1d5e7 stroke=#9673a6
    异常红: fill=#f8cecc stroke=#b85450
-->
<mxfile>
  <diagram name="Page-1">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200">
      <root>
        <!-- 固定根层 -->
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ============================================================
             图表标题
             ============================================================ -->
        <mxCell id="10" value="示例流程" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=0;fontStyle=1;fontSize=16;fontFamily=Microsoft YaHei;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="600" height="40" as="geometry"/>
        </mxCell>

        <!-- ============================================================
             Lane 1: OMS（蓝色，第一列）
             - swimlane: 容器样式，有标题栏和带边框的内容区
             - startSize=30: 标题栏高度 30px（顶部显示泳道名称）
             - horizontal=1: 标题水平显示在顶部
             - 每条泳道是独立的 swimlane 容器，相邻泳道的边框
               形成自然的列分隔线
             ============================================================ -->
        <mxCell id="11" value="OMS 订单系统" style="swimlane;startSize=30;horizontal=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Microsoft YaHei;fontSize=12;fontStyle=1;collapsible=0;container=1;swimlaneBody=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="60" width="200" height="550" as="geometry"/>
        </mxCell>

        <!-- ============================================================
             Lane 2: WMS（绿色，第二列，紧邻第一列）
             ============================================================ -->
        <mxCell id="12" value="WMS 仓储系统" style="swimlane;startSize=30;horizontal=1;fillColor=#d5e8d4;strokeColor=#82b366;fontFamily=Microsoft YaHei;fontSize=12;fontStyle=1;collapsible=0;container=1;swimlaneBody=1;" vertex="1" parent="1">
          <mxGeometry x="220" y="60" width="200" height="550" as="geometry"/>
        </mxCell>

        <!-- ============================================================
             Lane 3: TMS（橙色，第三列）
             ============================================================ -->
        <mxCell id="13" value="TMS 运输系统" style="swimlane;startSize=30;horizontal=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontFamily=Microsoft YaHei;fontSize=12;fontStyle=1;collapsible=0;container=1;swimlaneBody=1;" vertex="1" parent="1">
          <mxGeometry x="420" y="60" width="200" height="550" as="geometry"/>
        </mxCell>

        <!-- ============================================================
             节点（Nodes）
             - parent 指向所属泳道列的 ID
             - 坐标 (x, y) 相对于泳道列的左上角
             - y 值决定节点在流程中的纵向位置（行）
             ============================================================ -->

        <!-- Node 1: 矩形处理节点（OMS 列，第1行） -->
        <mxCell id="20" value="创建出库单" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Microsoft YaHei;fontSize=12;" vertex="1" parent="11">
          <mxGeometry x="40" y="50" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- Node 2: 菱形判断节点（OMS 列，第2行） -->
        <mxCell id="21" value="库存校验" style="rhombus;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Microsoft YaHei;fontSize=12;" vertex="1" parent="11">
          <mxGeometry x="50" y="150" width="100" height="60" as="geometry"/>
        </mxCell>

        <!-- Node 3: 处理节点（WMS 列，第3行） -->
        <mxCell id="22" value="生成拣货任务" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontFamily=Microsoft YaHei;fontSize=12;" vertex="1" parent="12">
          <mxGeometry x="40" y="250" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- Node 4: 处理节点（WMS 列，第4行） -->
        <mxCell id="23" value="出库确认" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontFamily=Microsoft YaHei;fontSize=12;" vertex="1" parent="12">
          <mxGeometry x="40" y="350" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- Node 5: 处理节点（TMS 列，第5行） -->
        <mxCell id="24" value="安排揽收" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontFamily=Microsoft YaHei;fontSize=12;" vertex="1" parent="13">
          <mxGeometry x="40" y="450" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- Node 6: 异常路径节点（OMS 列，第3行，红色样式） -->
        <mxCell id="25" value="库存不足处理" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontFamily=Microsoft YaHei;fontSize=12;" vertex="1" parent="11">
          <mxGeometry x="40" y="250" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- ============================================================
             连线（Edges）
             - parent="1": 连线挂在顶层，支持跨泳道列连线
             - source/target: 引用节点 ID
             - 正交连线在列之间自动路由
             ============================================================ -->

        <!-- Edge: 创建出库单 → 库存校验（同列内，向下） -->
        <mxCell id="30" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontFamily=Microsoft YaHei;fontSize=11;" edge="1" source="20" target="21" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Edge: 库存校验 → 生成拣货任务（跨列 OMS→WMS，标注"充足"） -->
        <mxCell id="31" value="充足" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontFamily=Microsoft YaHei;fontSize=11;" edge="1" source="21" target="22" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Edge: 库存校验 → 库存不足处理（同列内，异常路径红色） -->
        <mxCell id="32" value="不足" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#b85450;strokeWidth=2;fontFamily=Microsoft YaHei;fontSize=11;" edge="1" source="21" target="25" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Edge: 生成拣货任务 → 出库确认（同列内，向下） -->
        <mxCell id="33" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontFamily=Microsoft YaHei;fontSize=11;" edge="1" source="22" target="23" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Edge: 出库确认 → 安排揽收（跨列 WMS→TMS） -->
        <mxCell id="34" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontFamily=Microsoft YaHei;fontSize=11;" edge="1" source="23" target="24" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Edge: 安排揽收 → 出库确认（跨列 TMS→WMS，异步回调虚线） -->
        <mxCell id="35" value="回传运单号" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;dashPattern=8 4;fontFamily=Microsoft YaHei;fontSize=11;" edge="1" source="24" target="23" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
